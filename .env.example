# --- Application ---
APP_ENV=local
LOG_LEVEL=INFO

# --- Database (async SQLAlchemy + asyncpg) ---
DATABASE_URL=postgresql+asyncpg://booking:booking@db:5432/booking

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Worker behaviour ---
FAILURE_RATE=0.15        # probability the mock external service fails
MAX_RETRIES=3            # attempts before a booking is marked `failed`
RETRY_BASE_DELAY=2       # seconds before the first retry (grows exponentially)
RETRY_MAX_DELAY=60       # seconds, upper bound for backoff

# --- Rate limiting---
RATE_LIMIT=10/minute
RATE_LIMIT_STORAGE=memory:// 

# --- PostgreSQL ---
POSTGRES_USER=booking
POSTGRES_PASSWORD=booking
POSTGRES_DB=booking
